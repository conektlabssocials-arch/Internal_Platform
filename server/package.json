{
  "name": "conekt-ads-internal-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "test": "tsx --test --test-concurrency=1 src/services/*.test.ts src/utils/*.test.ts src/mcp/*.test.ts tests/*.test.ts",
    "test:unit": "tsx --test src/services/*.test.ts src/utils/*.test.ts src/mcp/*.test.ts",
    "test:integration": "tsx --test --test-concurrency=1 tests/*.test.ts",
    "test:watch": "tsx --test --watch src/services/*.test.ts tests/*.test.ts",
    "test:coverage": "tsx --test --experimental-test-coverage --test-concurrency=1 src/services/*.test.ts src/mcp/*.test.ts tests/*.test.ts",
    "start": "node dist/server.js",
    "seed:admin": "tsx src/scripts/seedAdmin.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^24.43.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/hpp": "^0.2.7",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.19",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^7.2.0",
    "mongodb-memory-server": "^11.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
