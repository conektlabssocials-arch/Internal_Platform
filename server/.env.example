PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/conekt_ads_internal
CLIENT_URL=http://localhost:5173
DOCUMENT_STORAGE=cloudinary
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_ALLOWED_DOMAIN=conektads.com
GEOCODING_PROVIDER=nominatim
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_FOLDER=inventory
CLOUDINARY_DOCUMENT_FOLDER=documents
CLOUDINARY_DOCUMENT_DELIVERY_TYPE=authenticated
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
JWT_SECRET=replace_this_secret
JWT_EXPIRES_IN=8h
COOKIE_NAME=conekt_ads_token
COOKIE_SECURE=true
MCP_ENABLED=false
MCP_AUTH_MODE=token
MCP_BASE_URL=http://localhost:5000
MCP_ACCESS_TOKEN=replace_with_a_long_random_token
MCP_ACTOR_EMAIL=admin@conektads.com
MCP_SHARED_SCOPES=platform:read campaigns:write plans:write operations:write
