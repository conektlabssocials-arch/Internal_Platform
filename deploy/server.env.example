NODE_ENV=production
PORT=5000
MONGO_URI=mongodb://mongo:27017/conekt_ads_internal
CLIENT_URL=https://internal.conektads.com
SERVER_URL=https://internal.conektads.com
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALLBACK_URL=https://internal.conektads.com/api/auth/google/callback
GOOGLE_WORKSPACE_DOMAIN=conektads.com
AUTH_ALLOWED_DOMAINS=conektads.com
DEV_AUTH_ENABLED=false
GEOCODING_PROVIDER=nominatim
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_FOLDER=inventory
CLOUDINARY_DOCUMENT_FOLDER=documents
CLOUDINARY_DOCUMENT_DELIVERY_TYPE=authenticated
UPLOAD_STORAGE=cloudinary
MAX_UPLOAD_SIZE_MB=50
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=8h
COOKIE_NAME=conekt_ads_internal_token
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=500
AUTH_RATE_LIMIT_MAX_REQUESTS=20
MCP_ENABLED=false
MCP_AUTH_MODE=oauth
MCP_BASE_URL=https://internal-api.conektads.com
MCP_ACCESS_TOKEN=replace_with_a_long_random_token
MCP_ACTOR_EMAIL=admin@conektads.com
MCP_SHARED_SCOPES=platform:read campaigns:write plans:write operations:write documents:write uploads:write shares:write crm:write inventory:write reports:read
MCP_MAX_UPLOAD_BYTES=6291456
